{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranchPatterns": [
    "main",
    "/^release-\\d+\\.\\d+/"
  ],
  "addLabels": [
    "lgtm"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)konflux-patch\\.sh$/"],
      "matchStrings": [
        "export MULTICLUSTER_GLOBAL_HUB_POSTGRESQL_IMAGE=registry.redhat.io/rhel9/postgresql-16@(?<currentDigest>sha256:[a-f0-9]+)\\n"
      ],
      "depNameTemplate": "registry.redhat.io/rhel9/postgresql-16",
      "datasourceTemplate": "docker",
      "currentValueTemplate": "16"
    }
  ]
}
